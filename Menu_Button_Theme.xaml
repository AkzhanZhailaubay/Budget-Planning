<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--set styling for all menu buttons-->
    <Style BasedOn="{StaticResource {x:Type ToggleButton}}" 
           TargetType="{x:Type RadioButton}"
           x:Key="Menu_Button_Theme">
        <Style.Setters>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border CornerRadius="15,0,15,0"
                                Background="{TemplateBinding Background}">

                            <Grid VerticalAlignment="Stretch"
                                  HorizontalAlignment="Stretch "
                                  Cursor="None"
                                   Background="Transparent">
                                <!--text bound to TextBlock content in view  -->
                                  <TextBlock Text="{TemplateBinding Property=Content}"
                                           VerticalAlignment="Center"
                                           Cursor="None"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontStyle="Italic"
                                           FontWeight="Bold"
                                           FontFamily="Century Gothic" 
                                           Margin="20,10,0,10"/>
                                <!--template bind background and foreground to change in dark mode-->
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!--set default values for foreground and background-->
            <Setter Property="Foreground"  Value="#343B44"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style.Setters>
           <!--change template binding properties when-->
        <Style.Triggers>
            <Trigger Property="IsMouseOver"  Value="True">
                <!--if mouse is over then-->
                <Setter Property="Background" Value="#E4E6E7"/>
            </Trigger> 
            <Trigger Property="IsChecked" Value="True">
                <!--change when button checked then-->
                <Setter Property="Foreground"  Value="#FF693E"/>
            </Trigger>
            <DataTrigger Binding="{Binding ElementName=cb_Dark, Path=IsChecked}" Value="True">
                <!--when in dark mode foreground changes-->
                <Setter Property="Foreground"  Value="#E4E6E7"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ElementName=cb_Dark, Path=IsChecked}" Value="True"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsChecked}" Value="True"/>
                     <!--if in dark mode and checked-->
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter Property="Foreground"  Value="#FF693E"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ElementName=cb_Dark, Path=IsChecked}" Value="True"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    <!--if in dark mode and mouse is over-->
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter Property="Background" Value="#343B44"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
        </Style.Triggers>

    </Style>
</ResourceDictionary>